function weekStatus(){
  const [a,b]=wkRange();
  const lo=a<=b?a:b, hi=a<=b?b:a;
  const today=new Date(); today.setHours(0,0,0,0);
  // The live operational week start is derived from the 2-pin clock cycle (weekStart()).
  // Any viewed week that begins after the live week's start sits entirely in the future.
  const liveStart=localDateStr(weekStart());
  if(lo>liveStart) return 'pending';
  // Credited once the calendar reaches the configured pay/milestone day that falls
  // immediately after this week's end. We advance from the week-end date to the first
  // occurrence of the credit weekday strictly after it (e.g. Wed end + next Friday).
  const cd=creditDay();
  const creditDate=parseLocal(hi); creditDate.setHours(0,0,0,0);
  do{creditDate.setDate(creditDate.getDate()+1);}while(creditDate.getDay()!==cd);
  return today>=creditDate ? 'credited' : 'current';
}
