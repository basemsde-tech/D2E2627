async function connectAndSignIn(create){
  let cfg;
  try{cfg=JSON.parse($('#firebaseConfig').value);}
  catch(e){toast('Invalid Firebase config JSON');return;}
  const email=($('#syncEmail').value||'').trim(), pass=$('#syncPassword').value||'';
  if(!email||!pass){toast('Enter email and password');return;}
  localStorage.setItem(KEYS.fb,JSON.stringify(cfg));
  try{
    if(!fb.app)await initFirebase(cfg);
    if(create)await fb.authFns.signUp(fb.auth,email,pass);
    else       await fb.authFns.signIn(fb.auth,email,pass);
    localStorage.setItem('d2e_sync_email',email);
    toast(create?'Account created \u2013 syncing\u2026':'Signed in \u2013 syncing\u2026');
  }catch(e){toast('Sign-in failed: '+(e&&(e.code||e.message)||'error'));setSyncStatus('error');}
}
