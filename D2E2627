    .pill.active,.primary{background:linear-gradient(135deg,var(--gold3),var(--gold2));color:#150d00;border-color:transparent}
    .hero{padding:16px;margin:12px 0;overflow:hidden}.hero-head{display:flex;align-items:center;justify-content:space-between}
    .total{font-size:56px;line-height:.95;margin:12px 0 8px;background:linear-gradient(180deg,#fff,var(--gold3));-webkit-background-clip:text;background-clip:text;color:transparent;transition:transform .18s}
