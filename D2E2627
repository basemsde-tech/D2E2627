let state={entries:loadArr(KEYS.entries),weekly:loadObj(KEYS.weekly),fuel:loadObj(KEYS.fuel),trip:loadObj(KEYS.trip),cash:loadObj(KEYS.cash),receipts:loadObj(KEYS.receipts),expenses:loadArr(KEYS.expenses),messages:loadObj(KEYS.messages),quickShare:(()=>{const q=load(KEYS.quickShare,{name:'',number:''});return (q&&typeof q==='object'&&!Array.isArray(q))?{name:q.name||'',number:q.number||''}:{name:'',number:''}})(),regos:(()=>{const r=loadArr(KEYS.regos).filter(x=>typeof x==='string'&&x.trim());return r.length?r:['ABC 123']})(),profile:(()=>{const p=load(KEYS.profile,{name:'Driver',email:''});return (p&&typeof p==='object'&&!Array.isArray(p))?{name:p.name||'Driver',email:p.email||''}:{name:'Driver',email:''}})(),snapshots:loadObj(KEYS.snapshots),weekOffset:0,receiptFilter:'all',firebase:null};
let calc=load(KEYS.shift,{date:localDateStr(new Date()),rego:localStorage.getItem(KEYS.lastRego)||state.regos[0]||'',eos:[0],cash:[{name:'',amount:0}],runs:0,accounts:[],fuelAmount:0,fuelType:localStorage.getItem(KEYS.fuelDefault)||'Diesel',hailTrips:''});
