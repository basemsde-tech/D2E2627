    .metric .m-top .dot{width:7px;height:7px}
    .metric .m-val{font-family:"Bricolage Grotesque",sans-serif;font-size:23px;color:var(--gold3);margin:6px 0 2px;font-variant-numeric:tabular-nums;white-space:nowrap}
    .metric .m-sub{font-size:10.5px;color:var(--muted)}
    .metric .m-warn{display:flex;align-items:center;gap:5px;margin-top:7px;font-size:10.5px;font-weight:800;color:var(--gold3)}
    .metric .m-warn svg{width:13px;height:13px;flex:0 0 auto}
    .fuel-pill{display:inline-flex;align-items:center;gap:5px;margin-top:8px;background:var(--bg3);border:1px solid var(--border);border-radius:999px;padding:3px 9px;font-size:10px;color:var(--text);font-weight:600;white-space:nowrap;max-width:100%;overflow:hidden}
    .fuel-pill b{color:var(--gold3)}
    .export-hub{padding:13px 14px}
    .export-hub .exp-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
    .export-cluster{display:grid;grid-template-columns:1fr 1fr;gap:8px}
    .export-cluster button{border-radius:13px;padding:14px;font-weight:800;font-size:14px;transition:transform .1s}
    .export-cluster button:active{transform:scale(.98)}
    .export-cluster .exp-copy{background:var(--bg3);border:1px solid var(--border);color:var(--text)}
    .export-cluster .exp-dl{background:linear-gradient(135deg,var(--gold3),var(--gold2));color:#150d00;border:0}
    /* ── Tax Expenses smart card ── */
    .exp-card{padding:0;overflow:hidden;margin-bottom:9px}
    .exp-head{width:100%;display:flex;align-items:center;justify-content:space-between;gap:10px;background:transparent;padding:14px;color:var(--text)}
    .exp-head-right{display:flex;align-items:center;gap:9px}
    .exp-total{font-family:"Bricolage Grotesque",sans-serif;font-size:18px;color:var(--gold3)}
    .exp-chev{width:18px;height:18px;color:var(--muted);transition:transform .25s}
    .exp-card.open .exp-chev{transform:rotate(180deg)}
    .exp-body{display:none;padding:0 13px 13px}
    .exp-card.open .exp-body{display:block}
    .exp-summary{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;margin-bottom:9px}
    .exp-summary .stat{padding:9px 7px;text-align:center}
    .exp-summary .stat small{font-size:9.5px;text-transform:uppercase;letter-spacing:.3px}
    .exp-summary .stat b{font-size:16px;color:var(--gold3)}
    .exp-recur-note{font-size:10.5px;color:var(--gold3);background:rgba(212,160,23,.1);border:1px solid rgba(212,160,23,.3);border-radius:8px;padding:6px 9px;margin-bottom:9px}
    .exp-quick{display:flex;flex-direction:column;gap:8px}
    .exp-amount{font-size:18px!important;font-weight:700;padding:13px 12px}
    .exp-chips{display:flex;gap:6px;overflow-x:auto;-webkit-overflow-scrolling:touch;padding-bottom:3px;scrollbar-width:none}
    .exp-chips::-webkit-scrollbar{display:none}
    .exp-chip{flex:0 0 auto;white-space:nowrap;background:var(--bg2);border:1px solid var(--border);color:var(--text);border-radius:999px;padding:8px 13px;font-size:12.5px;font-weight:700;min-height:38px;transition:transform .1s,background .15s}
    .exp-chip:active{transform:scale(.95)}
    .exp-chip.active{background:linear-gradient(135deg,var(--gold3),var(--gold2));color:#150d00;border-color:transparent}
    .exp-chip.more{border-style:dashed}
    .exp-actions{display:flex;align-items:center;gap:7px;flex-wrap:wrap}
    .exp-receipt{display:inline-flex;align-items:center;gap:6px;background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:9px 12px;font-size:12.5px;font-weight:700;cursor:pointer;flex:0 0 auto}
    .exp-receipt svg{width:16px;height:16px;color:var(--gold3)}
    .exp-recur-toggle{display:inline-flex;align-items:center;gap:7px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:10px;padding:9px 12px;font-size:12.5px;font-weight:700;flex:0 0 auto}
    .exp-recur-toggle .ert-dot{width:13px;height:13px;border-radius:50%;border:2px solid var(--muted);transition:.15s}
    .exp-recur-toggle.on{border-color:var(--gold3);color:var(--gold3)}
    .exp-recur-toggle.on .ert-dot{background:var(--gold3);border-color:var(--gold3);box-shadow:0 0 0 3px rgba(212,160,23,.18)}
    .exp-freq{width:auto;min-width:104px;flex:0 0 auto}
    .exp-details-toggle{background:transparent;border:0;color:var(--gold3);font-size:12px;font-weight:700;text-align:left;padding:2px 0}
    .exp-more-fields{display:flex;flex-direction:column;gap:8px}
    .exp-more-fields .row{margin:0}
    .exp-gst{font-size:10px;font-weight:700;color:var(--green)}
    .exp-recur-tag{font-size:9.5px;font-weight:800;color:var(--gold3);background:rgba(212,160,23,.12);border-radius:999px;padding:1px 6px}
    .qf button{flex:1 1 0;min-height:40px;border-radius:10px;border:1px solid var(--border);background:var(--bg2);color:var(--text);font-weight:700;font-size:12.5px;display:flex;align-items:center;justify-content:center;padding:0 8px;transition:transform .1s,background .15s}
    .qf button:active{transform:scale(.96)}
    .qf button.active{background:linear-gradient(135deg,var(--gold3),var(--gold2));color:#150d00;border-color:transparent}
    .daterow{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px}
    .datefield{display:flex;flex-direction:column;gap:1px;background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:6px 11px;min-height:46px;justify-content:center}
    .datefield small{color:var(--muted);font-size:10px;text-transform:uppercase;letter-spacing:.6px}
    .datefield input{border:0;background:transparent;padding:0;font-weight:700;font-size:15px;color:var(--text);width:100%}
    .weeknav{display:flex;gap:8px;align-items:center;margin-bottom:8px}
    .weeknav .wklabel{flex:1;text-align:center;font-weight:800;font-size:14px;font-family:"Bricolage Grotesque",sans-serif}
    .weeknav button{width:48px;min-height:46px;border-radius:10px;border:1px solid var(--border);background:var(--bg2);color:var(--gold3);font-size:20px;font-weight:800;display:flex;align-items:center;justify-content:center;transition:transform .1s}
    .weeknav button:active{transform:scale(.94)}
    .hero-sum{padding:16px;margin-bottom:10px;border-top:3px solid var(--gold)}
    .hero-sum .hs-total{font-family:"Bricolage Grotesque",sans-serif;font-size:44px;line-height:1;color:var(--gold3);margin:8px 0 4px;font-variant-numeric:tabular-nums}
    .hero-sum .hs-sub{color:var(--muted);font-size:12px}
    /* ── Sync dot indicator ── */
    .sync-dot{width:8px;height:8px;border-radius:50%;background:var(--muted);flex:0 0 auto;transition:background .3s}
    .sync-dot.live{background:var(--green);box-shadow:0 0 0 3px rgba(50,213,131,.2);animation:syncPulse 2.5s ease-in-out infinite}
    .sync-dot.error{background:var(--red)}
    .sync-dot.idle{background:var(--muted)}
    @keyframes syncPulse{0%,100%{box-shadow:0 0 0 3px rgba(50,213,131,.2)}50%{box-shadow:0 0 0 6px rgba(50,213,131,.05)}}
    .sync-row{display:flex;align-items:center;gap:8px;margin-top:8px}
    /* ── Weekly status bar ── */
    .wk-status-toggle{width:34px;height:34px;border-radius:999px;background:var(--bg3);border:1px solid var(--border);color:var(--gold3);display:grid;place-items:center;flex:0 0 auto;transition:transform .25s}
    .wk-status-toggle svg{width:17px;height:17px;transition:transform .25s}
    .wk-status-toggle.hidden svg{transform:rotate(-90deg)}
    .wk-status{display:flex;align-items:center;justify-content:space-between;gap:10px;background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:11px 14px;margin-bottom:9px;box-shadow:var(--shadow);overflow:hidden;transition:max-height .3s ease,opacity .25s ease,padding .25s ease,margin .25s ease;max-height:60px;opacity:1}
    .wk-status.collapsed{max-height:0;opacity:0;padding-top:0;padding-bottom:0;margin-bottom:0;border-width:0}
    .wk-status-label{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.7px;font-weight:700}
    .wk-badge{display:inline-flex;align-items:center;gap:6px;border-radius:999px;padding:5px 13px;font-size:13px;font-weight:800;font-family:"Bricolage Grotesque",sans-serif}
    .wk-badge::before{content:"";width:7px;height:7px;border-radius:50%;background:currentColor}
    .wk-badge.current{background:rgba(212,160,23,.15);color:var(--gold3);border:1px solid rgba(212,160,23,.4)}
    .wk-badge.credited{background:rgba(50,213,131,.13);color:var(--green);border:1px solid rgba(50,213,131,.4)}
    .wk-badge.pending{background:rgba(125,162,255,.12);color:var(--slate);border:1px solid rgba(125,162,255,.42)}
    /* ── Redesigned settings groups ── */
    .set-group{margin-bottom:14px}
    .set-group-title{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;font-weight:800;margin:0 0 8px 4px}
    .set-card{background:rgba(17,17,17,.88);border:1px solid var(--border);border-radius:14px;overflow:hidden;box-shadow:var(--shadow)}
    [data-theme="light"] .set-card{background:rgba(255,255,255,.9)}
    .set-item{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:13px 14px;border-bottom:1px solid var(--border);width:100%;background:transparent;text-align:left}
    .set-item:last-child{border-bottom:0}
    .set-item .si-label{min-width:0}
    .set-item .si-label b{display:block;font-size:14.5px;font-weight:700}
    .set-item .si-label p{margin:1px 0 0;font-size:11.5px;color:var(--muted)}
    .set-item .si-control{flex:0 0 auto;display:flex;align-items:center;gap:8px}
    .set-item input,.set-item select{width:auto;min-width:88px;max-width:130px;padding:8px 10px;border-radius:9px}
    .set-item.stack{flex-direction:column;align-items:stretch;gap:9px}
    .set-chev{color:var(--muted);font-size:18px;line-height:1}
    /* ── Validation error styling ── */
    .field-error{outline:2px solid var(--red)!important;outline-offset:-1px}
    .validate-msg{display:none;background:rgba(224,82,82,.12);border:1px solid rgba(224,82,82,.4);color:var(--red);border-radius:10px;padding:10px 12px;font-size:12.5px;font-weight:600;margin:0 0 10px;line-height:1.4}
    .validate-msg.show{display:block;animation:vshake .35s}
    @keyframes vshake{0%,100%{transform:translateX(0)}25%{transform:translateX(-5px)}75%{transform:translateX(5px)}}
    .chip[data-chip="hail"].required>button .chip-title::after,.chip[data-chip="receipt"].required>button .chip-title::after{content:"Required";font-size:10px;font-weight:800;color:var(--red);background:rgba(224,82,82,.13);border:1px solid rgba(224,82,82,.35);border-radius:999px;padding:2px 7px;margin-left:7px}
    .chip.field-error{outline:2px solid var(--red);outline-offset:-1px}
    /* ── Week-cycle clock selector ── */
    .weekclock-wrap{display:flex;flex-direction:column;align-items:center;gap:9px;width:100%;padding:4px 0 2px}
    .weekclock{display:flex;justify-content:center;width:100%}
    .weekclock svg{width:218px;height:218px;max-width:74vw;touch-action:none;-webkit-user-select:none;user-select:none}
    .wc-track{fill:none;stroke:var(--border);stroke-width:6}
    .wc-arc{fill:none;stroke:var(--gold3);stroke-width:6;stroke-linecap:round;opacity:.92;transition:d .12s}
    .wc-dot-mark{fill:var(--muted);transition:fill .15s}
    .wc-dot-mark.startday,.wc-dot-mark.endday{fill:#150d00}
    .wc-label{fill:var(--muted);font:700 12px Outfit,sans-serif;text-anchor:middle;dominant-baseline:central;pointer-events:none;transition:fill .15s}
    .wc-label.startday{fill:var(--gold3)}
    .wc-label.endday{fill:var(--text)}
    .wc-pin{cursor:grab}
    .wc-pin-start{fill:url(#wcg);stroke:#150d00;stroke-width:1}
    .wc-pin-end{fill:var(--bg2);stroke:var(--gold3);stroke-width:2.5}
    .wc-pin-txt{font:800 11px Outfit,sans-serif;text-anchor:middle;dominant-baseline:central;pointer-events:none}
    .wc-center{fill:var(--text);font:800 16px "Bricolage Grotesque",sans-serif;text-anchor:middle;dominant-baseline:central}
    .wc-center-sub{fill:var(--muted);font:600 9px Outfit,sans-serif;text-anchor:middle;dominant-baseline:central;text-transform:uppercase;letter-spacing:.6px}
    .wc-legend{display:flex;gap:16px;font-size:11.5px;color:var(--muted)}
    .wc-legend span{display:inline-flex;align-items:center;gap:5px}
    .wc-legend b{color:var(--text);font-weight:700}
    .wc-key{width:12px;height:12px;border-radius:50%;flex:0 0 auto}
    .wc-key.s{background:linear-gradient(135deg,var(--gold3),var(--gold2))}
    .wc-key.e{background:var(--bg2);border:2px solid var(--gold3)}
    @media (min-width:600px){.tabbar{width:430px}.app{border-left:1px solid var(--border);border-right:1px solid var(--border)}}
  </style>
</head>
<body>
<main class="app" id="app">
  <section class="screen active" data-screen="shift">
    <header class="top">
      <button class="hello" data-go="profile" aria-label="Open profile">
        <span class="avatar" id="avatar">D2</span>
        <span class="hello-text"><h1 id="greeting">Hey, Driver</h1><p id="todayLabel">Today</p></span>
      </button>
      <div class="island" id="island">
        <button class="island-row" id="islandToggle" aria-label="Weather details">
          <svg class="wx-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.5 1.5M17.5 17.5L19 19M19 5l-1.5 1.5M6.5 17.5L5 19"/></svg>
          <b id="temp">--</b>
          <span class="isl-div"></span>
          <span class="isl-date" id="miniDate">--</span>
        </button>
        <button class="iconbtn" id="themeBtn" aria-label="Toggle light or dark theme">
          <svg class="ico-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.5 1.5M17.5 17.5L19 19M19 5l-1.5 1.5M6.5 17.5L5 19"/></svg>
          <svg class="ico-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"/></svg>
        </button>
        <div class="island-panel">
          <b id="weatherDesc">Weather loading</b>
          <div class="grid"><div class="stat"><small>Suburb</small><b id="suburb">Melbourne</b></div><div class="stat"><small>Clock</small><b id="clock">--</b></div><div class="stat"><small>Humidity</small><b id="humidity">--</b></div><div class="stat"><small>Wind</small><b id="wind">--</b></div></div>
          <label class="muted" style="display:block;margin-top:10px;font-size:12px">Timezone</label>
          <select id="timezone"><option>Australia/Melbourne</option><option>Australia/Sydney</option><option>UTC</option><option>Asia/Kolkata</option></select>
        </div>
      </div>
    </header>
    <div class="card nudge" id="regoCard"><span><strong>Vehicle rego</strong><br><span id="nudgeSub">Hail trips are private and excluded from share text.</span></span><select id="regoSelect" class="rego-select" aria-label="Select rego"></select></div>
    <div class="date-strip">
      <button class="pill active" id="todayBtn">Today</button><button class="pill" id="yesterdayBtn">Yesterday</button><button class="pill" id="pickBtn">Pick</button>
    </div>
    <input type="date" id="shiftDate" style="position:absolute;width:1px;height:1px;opacity:0;border:0;padding:0;margin:0">
    <section class="card hero" id="shiftCapture">
      <div class="hero-head"><span class="mono muted">TOTAL AMOUNT</span><span class="tag" id="heroRego">No rego</span></div>
      <div class="total" id="takeHome">$0.00</div>
      <div class="formula mono" id="formula">(0 x 0.55) - 0 + 0 = 0</div>
      <div class="bar" id="bar"></div>
      <div class="legend">
        <div><small>EOS</small><b id="eosLegend">$0</b></div><div><small>Cash</small><b id="cashLegend">$0</b></div><div><small>Runs</small><b id="runsLegend">$0</b></div><div><small>Fuel</small><b id="fuelLegend">$0</b></div>
      </div>
    </section>
    <section class="chips" id="shiftChips">
      <article class="chip open" data-chip="eos"><button><span class="chip-title"><span class="dot"></span>EOS Takings</span><b id="eosChip">$0.00</b></button><div class="chip-content"><div id="eosRows"></div><button class="add" data-add="eos">Add EOS</button></div></article>
      <article class="chip" data-chip="cash"><button><span class="chip-title"><span class="dot"></span>Cash Income</span><b id="cashChip">$0.00</b></button><div class="chip-content"><div id="cashRows"></div><button class="add" data-add="cash">Add Cash</button></div></article>
      <article class="chip" data-chip="runs"><button><span class="chip-title"><span class="dot"></span>Runs &amp; Accounts</span><b id="runsChip">$0.00</b></button><div class="chip-content"><div class="row two"><input id="runCount" type="number" min="0" inputmode="numeric" placeholder="Passenger count"><input value="$5 / pax" disabled></div><div id="accountRows"></div><button class="add" data-add="account">Add Account</button></div></article>
      <article class="chip" data-chip="fuel"><button><span class="chip-title"><span class="dot"></span>Fuel</span><b id="fuelChip">$0.00</b></button><div class="chip-content"><div class="row two"><input id="fuelAmount" type="number" min="0" step="0.01" inputmode="decimal" placeholder="Fuel amount"><select id="fuelType"><option>Diesel</option><option>Petrol</option><option>LPG</option></select></div></div></article>
      <article class="chip" data-chip="hail"><button><span class="chip-title"><span class="dot"></span>Hail Trips</span><b id="hailChip">$0.00</b></button><div class="chip-content"><div class="row two"><input id="hailTrips" type="number" min="0" inputmode="numeric" placeholder="Trip count"><input id="levyDisplay" disabled></div></div></article>
      <article class="chip" data-chip="receipt"><button><span class="chip-title"><span class="dot"></span>Receipt Upload</span><b id="receiptChip">None</b></button><div class="chip-content"><input id="receiptFile" type="file" accept="image/*,application/pdf"><p class="muted" id="receiptName" style="font-size:12px"></p></div></article>
    </section>
    <div class="validate-msg" id="shareValidate"></div>
    <button class="primary" id="shareShift">Share End of Shift</button>
    <section class="card preview"><div id="messagePreview"></div><div class="preview-actions"><button class="secondary" id="copyMsg">Copy</button><button class="secondary" id="clearShift">Clear</button></div></section>
  </section>

  <section class="screen" data-screen="weekly">
    <div class="subhead"><div><h2>Weekly</h2></div><button class="wk-status-toggle" id="wkStatusToggle" aria-label="Toggle status badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></button></div>
    <div class="wk-status" id="wkStatusBar"><span class="wk-status-label">Status</span><span class="wk-badge" id="wkBadge">—</span></div>
    <div class="weeknav"><button id="wkPrev" aria-label="Previous week">&lsaquo;</button><span class="wklabel" id="wkLabel">Week</span><button id="wkNext" aria-label="Next week">&rsaquo;</button></div>
    <div class="daterow"><div class="datefield"><small>From</small><input type="date" id="wkStart"></div><div class="datefield"><small>To</small><input type="date" id="wkEnd"></div></div>
    <section class="card week-table" id="weekCapture"><div id="weekRows"></div><div class="total-row"><span class="muted">Total</span><b id="weekTotal">$0.00</b></div></section>
    <button class="primary" id="shareWeek" style="margin:10px 0 0">Share</button>
    <article class="chip" style="margin-top:10px"><button id="overrideToggle"><span class="chip-title"><span class="dot"></span>Add / Override Entry</span><b>+</b></button><div class="chip-content" id="overrideContent"><div class="row two"><input type="date" id="overrideDate"><input type="number" id="overrideAmount" placeholder="Amount"></div><div class="row two"><input id="overrideRego" placeholder="Rego"><button class="add" id="saveOverride">Save</button></div></div></article>
  </section>

  <section class="screen" data-screen="reports">
    <div class="subhead"><div><h2>Reports</h2></div></div>
    <div id="reports"></div>
  </section>

  <section class="screen" data-screen="settings">
    <div class="subhead"><div><p>Defaults &amp; data</p><h2>Settings</h2></div><span class="tag">v3.8</span></div>

    <div class="set-group">
      <p class="set-group-title">Account</p>
      <div class="set-card">
        <button class="set-item" data-go="profile"><span class="si-label"><b>Profile &amp; Sync</b><p id="syncSummary">Local only</p></span><span class="si-control"><span class="set-chev">›</span></span></button>
        <div class="set-item stack"><span class="si-label"><b>WhatsApp Quick Share</b><p id="quickShareSummary">No contact set</p></span>
          <div class="quick-share-grid"><input id="quickShareName" placeholder="Contact name"><input id="quickShareNumber" inputmode="tel" placeholder="WhatsApp number"></div>
          <div class="quick-share-actions"><button class="secondary" id="pickQuickShare">Pick</button><button class="secondary" id="saveQuickShare">Save</button><button class="secondary" id="clearQuickShare">Clear</button></div>
        </div>
      </div>
    </div>

    <div class="set-group">
      <p class="set-group-title">Shift Defaults</p>
      <div class="set-card">
        <div class="set-item"><span class="si-label"><b>Hail Trip Levy</b><p>Per trip ($)</p></span><span class="si-control"><input id="levyRate" type="number" min="0" step="0.01"></span></div>
        <div class="set-item"><span class="si-label"><b>Default Fuel</b><p>New shift forms</p></span><span class="si-control"><select id="defaultFuel"><option>Diesel</option><option>Petrol</option><option>LPG</option></select></span></div>
        <div class="set-item stack"><span class="si-label"><b>Vehicle Regos</b><p>Shown in the shift rego dropdown</p></span>
          <div style="display:grid;grid-template-columns:1fr auto;gap:8px;width:100%"><input id="newRego" placeholder="e.g. 5088M" autocapitalize="characters" autocomplete="off"><button class="secondary" id="addRego" style="white-space:nowrap">Add</button></div>
          <div id="regoChips" class="rego-chips"></div>
        </div>
      </div>
    </div>

    <div class="set-group">
      <p class="set-group-title">Work Week</p>
      <div class="set-card">
        <div class="set-item stack"><span class="si-label"><b>Week Cycle</b><p id="weekCycleHint">Thursday → Wednesday</p></span>
          <div class="weekclock-wrap"><div class="weekclock" id="weekClock"></div><div class="wc-legend"><span><span class="wc-key s"></span><b>Start</b></span><span><span class="wc-key e"></span><b>End</b></span></div></div>
        </div>
        <div class="set-item"><span class="si-label"><b>Credited On</b><p>Pay milestone after week ends</p></span><span class="si-control"><select id="creditDaySelect" style="min-width:108px;max-width:140px"></select></span></div>
      </div>
    </div>

    <div class="set-group">
      <p class="set-group-title">App</p>
      <div class="set-card">
        <div class="set-item"><span class="si-label"><b>Appearance</b><p>Dark or light</p></span><span class="si-control"><span class="switch"><button id="darkSwitch">Dark</button><button id="lightSwitch">Light</button></span></span></div>
        <button class="set-item" id="openReceipts"><span class="si-label"><b>Receipt Archive</b><p id="receiptCount">0 receipts</p></span><span class="si-control"><span class="set-chev">›</span></span></button>
        <button class="set-item" id="refreshApp"><span class="si-label"><b>Clear Cache &amp; Refresh</b><p>Keeps saved shifts &amp; receipts</p></span><span class="si-control"><span class="set-chev">›</span></span></button>
        <div class="set-item"><span class="si-label"><b>Version</b><p class="mono">3.8 · build 2026-06-07</p></span><span class="si-control"><span class="tag">Gold</span></span></div>
      </div>
    </div>
  </section>

