/* ── Clock-style week-cycle selector ──────────────────────────────────
   7 days arranged in a circle (Sun at top, clockwise). Two pins:
   • Start (filled gold knob) — the day the work week begins
   • End   (outlined knob)    — auto-locked to start+6 (full 7-day window)
   Dragging Start moves End to start+6; dragging End sets Start to end+1.
   This makes an invalid/overlapping/broken window impossible by construction. */
const WC={cx:120,cy:120,ring:84,lab:54,dot:4.5};
const DAY2=['Su','Mo','Tu','We','Th','Fr','Sa'];
function wcAngle(i){return -90 + i*(360/7);}
function wcPolar(r,deg){const a=deg*Math.PI/180;return [WC.cx+r*Math.cos(a),WC.cy+r*Math.sin(a)];}
function wcArcPath(sDeg,eDeg){const [x1,y1]=wcPolar(WC.ring,sDeg);const [x2,y2]=wcPolar(WC.ring,eDeg);return `M ${x1.toFixed(2)} ${y1.toFixed(2)} A ${WC.ring} ${WC.ring} 0 1 1 ${x2.toFixed(2)} ${y2.toFixed(2)}`;}
function renderWeekClock(){
  const host=document.getElementById('weekClock'); if(!host)return;
  if(document.getElementById('weekClockSvg')){updateWeekClock();return;}
  let nodes='';
  for(let i=0;i<7;i++){
    const [lx,ly]=wcPolar(WC.lab,wcAngle(i)), [dx,dy]=wcPolar(WC.ring,wcAngle(i));
    nodes+=`<circle class="wc-dot-mark" cx="${dx.toFixed(2)}" cy="${dy.toFixed(2)}" r="${WC.dot}" data-day="${i}"></circle>`;
    nodes+=`<text class="wc-label" x="${lx.toFixed(2)}" y="${ly.toFixed(2)}" data-day="${i}">${DAY2[i]}</text>`;
  }
  host.innerHTML=`<svg id="weekClockSvg" viewBox="0 0 240 240" role="group" aria-label="Week cycle selector clock">
    <defs><linearGradient id="wcg" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="var(--gold3)"/><stop offset="1" stop-color="var(--gold2)"/></linearGradient></defs>
    <circle class="wc-track" cx="120" cy="120" r="84"></circle>
    <path id="wcArc" class="wc-arc" d=""></path>
    ${nodes}
    <text id="wcCenter" class="wc-center" x="120" y="114"></text>
    <text id="wcCenterSub" class="wc-center-sub" x="120" y="132">tap or drag</text>
    <circle id="wcEndC" class="wc-pin wc-pin-end" r="15" data-pin="end"></circle>
    <text id="wcEndT" class="wc-pin-txt" style="fill:var(--gold3)">E</text>
    <circle id="wcStartC" class="wc-pin wc-pin-start" r="15" data-pin="start"></circle>
    <text id="wcStartT" class="wc-pin-txt" style="fill:#150d00">S</text>
  </svg>`;
  bindWeekClock();
  updateWeekClock();
}
function updateWeekClock(){
  const svg=document.getElementById('weekClockSvg'); if(!svg)return;
  const s=weekStartDay(), e=weekEndDay();
  document.getElementById('wcArc').setAttribute('d',wcArcPath(wcAngle(s),wcAngle(e)));
  const [sx,sy]=wcPolar(WC.ring,wcAngle(s)), [ex,ey]=wcPolar(WC.ring,wcAngle(e));
  const setPin=(cid,tid,x,y)=>{const c=document.getElementById(cid);c.setAttribute('cx',x.toFixed(2));c.setAttribute('cy',y.toFixed(2));const t=document.getElementById(tid);t.setAttribute('x',x.toFixed(2));t.setAttribute('y',y.toFixed(2));};
  setPin('wcStartC','wcStartT',sx,sy); setPin('wcEndC','wcEndT',ex,ey);
  svg.querySelectorAll('.wc-dot-mark,.wc-label').forEach(d=>{const i=+d.getAttribute('data-day');d.classList.toggle('startday',i===s);d.classList.toggle('endday',i===e);});
  document.getElementById('wcCenter').textContent=`${DAY2[s]} → ${DAY2[e]}`;
  const hint=document.getElementById('weekCycleHint'); if(hint)hint.textContent=weekCycleLabel();
}
function setWeekStartDayValue(day){ day=((day%7)+7)%7; if(day===weekStartDay())return false; setLS(KEYS.weekStartDay,String(day)); applyWeekCycleChange(); updateWeekClock(); return true; }
function bindWeekClock(){
  const svg=document.getElementById('weekClockSvg'); if(!svg||svg._bound)return; svg._bound=true;
  let drag=null;
  const nearestDay=e=>{ const r=svg.getBoundingClientRect(); if(!r.width)return weekStartDay(); const px=(e.clientX-r.left)*(240/r.width), py=(e.clientY-r.top)*(240/r.height); const a=Math.atan2(py-WC.cy,px-WC.cx)*180/Math.PI; let best=0,bd=1e9; for(let i=0;i<7;i++){const d=Math.abs(((a-wcAngle(i)+540)%360)-180); if(d<bd){bd=d;best=i;}} return best; };
  const apply=day=>{ if(drag==='end')setWeekStartDayValue((day+1)%7); else setWeekStartDayValue(day); };
  svg.addEventListener('pointerdown',e=>{ const pin=e.target.getAttribute&&e.target.getAttribute('data-pin'); drag=pin==='end'?'end':'start'; try{svg.setPointerCapture(e.pointerId);}catch(_){} apply(nearestDay(e)); e.preventDefault(); });
  svg.addEventListener('pointermove',e=>{ if(!drag)return; apply(nearestDay(e)); e.preventDefault(); });
  const stop=e=>{ if(drag){ drag=null; try{svg.releasePointerCapture(e.pointerId);}catch(_){} toast('Week cycle: '+weekCycleLabel()); } };
  svg.addEventListener('pointerup',stop); svg.addEventListener('pointercancel',stop);
}
