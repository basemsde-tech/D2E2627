  if(sum)sum.textContent=(syncOn&&userId)?'Firebase \u2022 Real-time':'Local only';
}

// ── Read local value for any key (state object or localStorage) ───────
function localValueFor(key){
  const p=KEY_TO_STATE[key];
  return p!==undefined?state[p]:localStorage.getItem(key);
}

// ── Persist a remote value WITHOUT triggering another push (no echo) ──
function rawPersist(key,value){
  const p=KEY_TO_STATE[key];
  try{
    if(p!==undefined){
      // Coerce to the shape this state field must have so a corrupt remote payload can't crash the UI
      const arrayKeys=[KEYS.entries,KEYS.expenses,KEYS.regos];
      if(arrayKeys.indexOf(key)>=0) value=Array.isArray(value)?value.filter(x=>x!=null):[];
      else if(value==null||typeof value!=='object'||Array.isArray(value)) value={};
      state[p]=value; localStorage.setItem(key,JSON.stringify(value));
    }
    else{if(value==null)localStorage.removeItem(key);else localStorage.setItem(key,typeof value==='string'?value:String(value));}
  }catch(e){}
}

// ── Write one key to Firestore (called by push queue) ─────────────────
async function cloudWrite(key){
  if(!syncOn||!fb.db||!userId||!fb.fns)return;
  const value=localValueFor(key);
  try{
    await fb.fns.setDoc(
      fb.fns.doc(fb.db,'accounts',userId,'data',key),
      {value,_deviceId:deviceId(),updatedAt:fb.fns.serverTimestamp()}
    );
    setSyncStatus('live');
  }catch(e){
    setSyncStatus('offline \u2013 queued');
    // Firestore offline persistence will automatically retry when back online
  }
}

// ── Push queue: immediate (0ms) or debounced (150ms) ─────────────────
function queuePush(key,immediate=false){
  if(!syncOn||SYNC_KEYS.indexOf(key)<0)return;
  if(immediate){
    clearTimeout(pushTimers[key]);
    delete pushTimers[key];
    immediateQueue.add(key);
    cloudWrite(key).finally(()=>immediateQueue.delete(key));
  }else{
    if(immediateQueue.has(key))return; // already in-flight, skip debounce
    clearTimeout(pushTimers[key]);
    pushTimers[key]=setTimeout(()=>cloudWrite(key),150);
  }
}

// ── Public API: called from save() and saveShift() ────────────────────
function autoSync(k){queuePush(k,false);}
function immediateSync(k){queuePush(k,true);}

// ── setLS: write a setting to localStorage + push to cloud ───────────
function setLS(key,val){
  if(val==null)localStorage.removeItem(key);
  else localStorage.setItem(key,val);
  queuePush(key,false);
}

// ── Convert Firestore timestamp to epoch ms ───────────────────────────
function tsMillis(u){
  if(!u)return 0;
  if(typeof u.toMillis==='function')return u.toMillis();
  if(u.seconds)return u.seconds*1000+(u.nanoseconds||0)/1e6;
  const nn=Date.parse(u); return isFinite(nn)?nn:0;
}

// ── Apply incoming remote snapshot (last-write-wins + echo guard) ─────
function applyRemote(key,data,hasPendingWrites){
  if(!data)return;
  // hasPendingWrites = this is our own write reflected from the local cache
  if(hasPendingWrites)return;
  const ts=tsMillis(data.updatedAt), prev=syncMeta[key]||0;
  // Echo: our own device's write reflected back with same or older timestamp
  if(data._deviceId===deviceId()&&ts&&ts<=prev)return;
  // Last-write-wins: we have a strictly newer confirmed value
  if(ts&&prev&&ts<prev)return;
  rawPersist(key,data.value);
  syncMeta[key]=ts||Date.now();
  try{localStorage.setItem('d2e_sync_meta',JSON.stringify(syncMeta));}catch(e){}
  refreshAfterSync(key);
}

// ── Smart re-render: only touch the screen that changed ───────────────
function refreshAfterSync(key){
  const active=document.querySelector('.screen.active');
  const scr=active&&active.dataset.screen;
  // Always refresh rego options and the shift calc (cheap, always needed)
  try{renderRegoOptions();renderRegoChips();}catch(e){}
  try{renderRows();renderCalc();}catch(e){}
  // Screen-specific re-renders
  try{if(scr==='reports')renderReports();}catch(e){}
  try{if(scr==='weekly')renderWeekly();}catch(e){}
  try{if(scr==='settings')renderSettings();}catch(e){}
  try{if(scr==='profile')renderProfile();}catch(e){}
  try{if(scr==='receipts')renderReceipts();}catch(e){}
}

// ── Union-merge local + cloud on first device join ────────────────────
// Neither side loses data; cloud wins on scalar conflicts
function mergeValues(key,localV,cloudV){
  if(cloudV==null)return localV;
  if(localV==null)return cloudV;
  if(key===KEYS.entries){
    // Array of shift objects — union by date+rego key
    const m={};
    (localV||[]).forEach(e=>e&&(m[e.date+'|'+(e.rego||'')]=e));
    (cloudV||[]).forEach(e=>e&&(m[e.date+'|'+(e.rego||'')]=e));
    return Object.values(m);
  }
  if(key===KEYS.expenses){
    // Array of expense objects — union by id
    const m={};
    (localV||[]).forEach(e=>e&&e.id&&(m[e.id]=e));
    (cloudV||[]).forEach(e=>e&&e.id&&(m[e.id]=e));
    return Object.values(m);
  }
  if(key===KEYS.regos){
    // String array — deduplicated union
    const out=[],seen={};
    [...(localV||[]),...(cloudV||[])].forEach(r=>{
      const k=String(r).toLowerCase();
      if(!seen[k]){seen[k]=1;out.push(r);}
    });
    return out;
  }
  if(Array.isArray(cloudV))return cloudV;
  if(typeof cloudV==='object'&&cloudV!==null&&typeof localV==='object'&&localV!==null)
    return Object.assign({},localV,cloudV); // object maps: union keys, cloud wins on collision
  return cloudV; // scalar settings: cloud value wins
}

// ── One-time reconciliation when a device joins/rejoins an account ────
async function reconcile(){
  if(!fb.db||!userId||!fb.fns)return;
  setSyncStatus('merging\u2026');
  for(const key of SYNC_KEYS){
    try{
      const ref=fb.fns.doc(fb.db,'accounts',userId,'data',key);
      const snap=await fb.fns.getDoc(ref);
      const exists=typeof snap.exists==='function'?snap.exists():snap.exists;
      const cloudV=exists?(snap.data&&snap.data()||{}).value:undefined;
      const merged=mergeValues(key,localValueFor(key),cloudV);
      rawPersist(key,merged);
      // Push merged value so cloud reflects the union too
      await fb.fns.setDoc(ref,{value:localValueFor(key),_deviceId:deviceId(),updatedAt:fb.fns.serverTimestamp()});
      syncMeta[key]=Date.now();
    }catch(e){}
  }
  try{localStorage.setItem('d2e_sync_meta',JSON.stringify(syncMeta));}catch(e){}
  refreshAfterSync('*');
}

// ── Attach real-time Firestore listeners (one per SYNC_KEY) ──────────
function attachListeners(){
  detachListeners();
  if(!fb.db||!userId||!fb.fns)return;
  SYNC_KEYS.forEach(key=>{
    try{
      const ref=fb.fns.doc(fb.db,'accounts',userId,'data',key);
      const u=fb.fns.onSnapshot(
        ref,
        snap=>{
          try{
            if(!snap)return;
            const exists=typeof snap.exists==='function'?snap.exists():snap.exists;
            const meta=snap.metadata||{};
            if(!exists){
              // Key missing from cloud — push our local value up immediately
              if(localValueFor(key)!=null&&!meta.hasPendingWrites)queuePush(key,true);
              return;
            }
            applyRemote(key,snap.data&&snap.data(),meta.hasPendingWrites);
          }catch(e){}
        },
        ()=>setSyncStatus('listener error')
      );
      unsub.push(u);
    }catch(e){}
  });
}
function detachListeners(){unsub.forEach(u=>{try{u&&u();}catch(e){}});unsub=[];}

// ── Network awareness: flush pending writes when connectivity returns ──
window.addEventListener('online',()=>{
  netOnline=true;
  setSyncStatus('reconnecting\u2026');
  if(syncOn&&userId){
    // Re-push all keys — Firestore queues failed writes, but this
    // ensures settings (non-Firestore-tracked) also get flushed
    SYNC_KEYS.forEach(k=>queuePush(k,false));
    setSyncStatus('live');
  }
});
window.addEventListener('offline',()=>{
  netOnline=false;
  setSyncStatus('offline \u2013 changes saved locally');
});

// ── Firebase SDK init (dynamic import, zero cost when not configured) ─
async function initFirebase(cfg){
  const [appMod,authMod,fsMod]=await Promise.all([
    import('https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js'),
    import('https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js'),
    import('https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js'),
  ]);
  // Reuse existing app if already initialized (handles hot-reload)
  try{fb.app=appMod.getApp();}catch{fb.app=appMod.initializeApp(cfg);}
  fb.auth=authMod.getAuth(fb.app);
  // Enable offline persistence with multi-tab support
  try{
    fb.db=fsMod.initializeFirestore(fb.app,{
      localCache:fsMod.persistentLocalCache({
        tabManager:fsMod.persistentMultipleTabManager?fsMod.persistentMultipleTabManager():undefined
      })
    });
  }catch(e){try{fb.db=fsMod.getFirestore(fb.app);}catch(_){}}
  fb.fns={doc:fsMod.doc,setDoc:fsMod.setDoc,getDoc:fsMod.getDoc,onSnapshot:fsMod.onSnapshot,serverTimestamp:fsMod.serverTimestamp};
  fb.authFns={signIn:authMod.signInWithEmailAndPassword,signUp:authMod.createUserWithEmailAndPassword,signOut:authMod.signOut};
  // Persist auth session across reloads / app restarts
  try{await authMod.setPersistence(fb.auth,authMod.browserLocalPersistence);}catch(e){}
  // Auth state observer — fires immediately on load if session is restored
  authMod.onAuthStateChanged(fb.auth,async user=>{
    if(user){
      userId=user.uid; syncOn=true;
      if(user.email)localStorage.setItem('d2e_sync_email',user.email);
      setSyncStatus('connecting\u2026');
      try{await reconcile();}catch(e){}
      attachListeners();
      setSyncStatus('live');
    }else{
      userId=null; syncOn=false;
      detachListeners();
      setSyncStatus('signed out');
    }
    updateSyncUI();
  });
}

