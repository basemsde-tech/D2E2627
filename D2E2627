// =====================================================================
// REAL-TIME MULTI-DEVICE SYNC ENGINE v2.8
// ─────────────────────────────────────────────────────────────────────
// Architecture:
//   • Firestore: accounts/{uid}/data/{key}  (one doc per data key)
//   • Offline persistence: persistentLocalCache (IndexedDB-backed)
//   • Conflict resolution: last-write-wins via serverTimestamp
//   • Initial join: union-merge — neither device loses data
//   • Echo prevention: _deviceId + timestamp guard
//   • Network awareness: online/offline events flush pending writes
//   • immediateSync() = zero-debounce (shift saves, rego changes)
//   • autoSync()      = 150ms debounce (all other saves)
// =====================================================================

const SYNC_DATA_KEYS=[KEYS.entries,KEYS.weekly,KEYS.fuel,KEYS.trip,KEYS.cash,KEYS.expenses,KEYS.messages,KEYS.snapshots,KEYS.regos,KEYS.quickShare,KEYS.profile];
const SYNC_SETTING_KEYS=[KEYS.levy,KEYS.fuelDefault,KEYS.lastRego,KEYS.tz,KEYS.weekStartDay,KEYS.creditDay];
const SYNC_KEYS=[...SYNC_DATA_KEYS,...SYNC_SETTING_KEYS];
const KEY_TO_STATE={[KEYS.entries]:'entries',[KEYS.weekly]:'weekly',[KEYS.fuel]:'fuel',[KEYS.trip]:'trip',[KEYS.cash]:'cash',[KEYS.expenses]:'expenses',[KEYS.messages]:'messages',[KEYS.snapshots]:'snapshots',[KEYS.regos]:'regos',[KEYS.quickShare]:'quickShare',[KEYS.profile]:'profile'};

let fb={app:null,auth:null,db:null,fns:null,authFns:null};
let syncOn=false, unsub=[], pushTimers={}, immediateQueue=new Set();
let syncMeta=load('d2e_sync_meta',{});
let netOnline=navigator.onLine;

// ── Device identity ───────────────────────────────────────────────────
function deviceId(){
  let id=localStorage.getItem(KEYS.device);
  if(!id){id=uid();localStorage.setItem(KEYS.device,id);}
  return id;
}

// ── Sync status UI ────────────────────────────────────────────────────
function setSyncStatus(s){
