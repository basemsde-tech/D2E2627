  const res={inserted:0,amended:0,unchanged:0,rejected:0,rejects:[],valid:[],rego:useRego};
  const existing={}; (state.entries||[]).forEach(e=>{ if(e&&e.date!==undefined)existing[e.date+'|'+(e.rego||'')]=+Number(e.amount).toFixed(2); });
  (dataset||[]).forEach(row=>{
