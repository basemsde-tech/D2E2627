const fmtDate=s=>parseLocal(s).toLocaleDateString('en-AU',{weekday:'short',day:'2-digit',month:'short'});
const ddmmyyyy=s=>parseLocal(s).toLocaleDateString('en-AU',{day:'2-digit',month:'2-digit',year:'numeric'});
const csvCell=v=>{let s=String(v??''); if(/^[=+\-@\t\r]/.test(s))s="'"+s; return /[",\n\r]/.test(s)?'"'+s.replace(/"/g,'""')+'"':s};
