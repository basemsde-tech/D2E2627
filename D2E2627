// Isolated per-row validator — guarantees schema match before commit
function sanitizeImportRow(row){
  try{
    if(!row||typeof row!=='object')return {ok:false,reason:'bad row'};
    const d=String(row.d!==undefined?row.d:row.date||'').trim();
    if(!/^\d{4}-\d{2}-\d{2}$/.test(d))return {ok:false,reason:'bad date format'};
    const dt=parseLocal(d); if(!dt||isNaN(dt.getTime())||localDateStr(dt)!==d)return {ok:false,reason:'invalid calendar date'};
    let a=row.a!==undefined?row.a:row.amount;
    if(typeof a==='string')a=Number(a.replace(/[^0-9.\-]/g,''));
    a=Number(a);
    if(!isFinite(a)||a<0||a>100000)return {ok:false,reason:'bad amount'};
    return {ok:true,entry:{date:d,amount:+a.toFixed(2)}};
  }catch(e){ return {ok:false,reason:'exception'}; }
}
