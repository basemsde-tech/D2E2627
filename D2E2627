    .formula{font-size:12px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .bar{height:10px;border-radius:999px;overflow:hidden;background:var(--bg3);display:flex;margin:13px 0}.bar span{height:100%;min-width:3px}
    .legend,.grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}.legend div,.stat{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:8px}
    .legend small,.stat small{display:block;color:var(--muted);font-size:11px}.legend b,.stat b{font-family:"Bricolage Grotesque";font-size:16px}
    [data-theme="light"] .hero{background:#0b0b0b!important;border-color:#232323;color:#f5f0e8;box-shadow:0 22px 70px rgba(0,0,0,.28)}
    [data-theme="light"] .hero .muted,[data-theme="light"] .hero .formula,[data-theme="light"] .hero .legend small{color:#bdb39f}
    [data-theme="light"] .hero .tag{background:rgba(212,160,23,.12);border-color:rgba(212,160,23,.35);color:#f0c040}
    [data-theme="light"] .hero .legend div{background:#191919;border-color:#292929;color:#f5f0e8}
    [data-theme="light"] .hero .bar{background:#222}
    .chips{display:grid;gap:9px}.chip{overflow:hidden}.chip>button{width:100%;display:flex;align-items:center;justify-content:space-between;text-align:left;background:transparent;padding:13px}
    .chip[data-chip="eos"]{border-color:rgba(240,192,64,.55);background:linear-gradient(135deg,rgba(212,160,23,.22),rgba(17,17,17,.9));box-shadow:0 18px 55px rgba(212,160,23,.16)}
    .chip[data-chip="eos"] .dot{width:18px;height:18px;border-radius:6px;background:linear-gradient(135deg,var(--gold3),var(--gold2));box-shadow:0 0 0 4px rgba(212,160,23,.12)}
    .chip[data-chip="eos"] b{font-size:20px;color:var(--gold3)}
    .chip[data-chip="receipt"]{border-style:dashed;border-color:rgba(245,240,232,.35);background:repeating-linear-gradient(135deg,rgba(255,255,255,.04) 0,rgba(255,255,255,.04) 8px,transparent 8px,transparent 16px),rgba(17,17,17,.88)}
    .chip[data-chip="receipt"] .dot{background:transparent;border:2px solid var(--gold3)}
    .chip[data-chip="receipt"] b{color:var(--gold3)}
    [data-theme="light"] .chip[data-chip="eos"]{background:linear-gradient(135deg,rgba(212,160,23,.2),rgba(255,255,255,.92))}
    [data-theme="light"] .chip[data-chip="receipt"]{border-color:rgba(24,14,0,.3);background:repeating-linear-gradient(135deg,rgba(184,134,11,.08) 0,rgba(184,134,11,.08) 8px,transparent 8px,transparent 16px),rgba(255,255,255,.9)}
    .chip-title{display:flex;align-items:center;gap:9px;font-weight:800}.dot{width:9px;height:9px;border-radius:50%;background:var(--gold3)}
    .chip-content{display:none;padding:0 13px 13px}.chip.open .chip-content{display:block}
    .row{display:grid;grid-template-columns:1fr 118px 34px;gap:8px;margin:8px 0}.row.two{grid-template-columns:1fr 118px}.row.one{grid-template-columns:1fr}
    input,select,textarea{width:100%;border:1px solid var(--border);background:var(--bg3);border-radius:8px;padding:11px 10px;outline:none}
    textarea{min-height:106px;resize:vertical}.mini{width:34px;height:42px;border-radius:8px;background:var(--bg3);border:1px solid var(--border)}
    .add,.secondary{border:1px solid var(--border);background:var(--bg3);border-radius:8px;padding:10px 12px;font-weight:800}
    .primary{width:100%;border-radius:8px;padding:14px 15px;font-weight:900;margin:12px 0 10px}
    .preview{padding:12px;white-space:pre-wrap;font-family:"Geist Mono";font-size:12px;line-height:1.55}.preview-actions{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px}
    .screen{display:none}.screen.active{display:block}.subhead{display:flex;align-items:end;justify-content:space-between;margin:7px 0 12px}.subhead h2{font-size:30px}.subhead p{margin:0;color:var(--muted);font-size:12px}
    .week-table{padding:12px;border-top:4px solid var(--gold);overflow:hidden}.table-row{display:grid;grid-template-columns:1fr .7fr .78fr 52px 38px;gap:8px;align-items:center;padding:10px 0;border-bottom:1px solid var(--border);font-size:13px}
    .table-row.head{color:var(--muted);font-size:11px;text-transform:uppercase}.tag{display:inline-flex;border:1px solid rgba(212,160,23,.35);background:rgba(212,160,23,.1);color:var(--gold3);border-radius:999px;padding:4px 7px;font-size:11px}
    .total-row{display:flex;align-items:center;justify-content:space-between;border-top:1px dashed var(--border);margin-top:10px;padding-top:13px}.total-row b{font-family:"Bricolage Grotesque";font-size:28px;color:var(--gold3)}
    .filter{display:flex;gap:6px;overflow:auto;padding-bottom:8px}.filter button{white-space:nowrap}
    .expense-form{display:grid;gap:8px;margin:8px 0}.expense-form .row{margin:0}.expense-list{display:grid;gap:7px;margin-top:10px}.expense-item{display:grid;grid-template-columns:1fr auto;gap:8px;align-items:center;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:9px}.expense-item small{display:block;color:var(--muted);font-size:11px}.expense-item b{color:var(--gold3)}
    .checkline{display:flex;align-items:center;gap:8px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px}.checkline input{width:auto}
    .settings-list{display:grid;gap:9px}.setting{display:grid;grid-template-columns:1fr auto;gap:10px;align-items:center;padding:12px}.setting p{margin:2px 0 0;color:var(--muted);font-size:12px}
    .setting.full{display:block}.quick-share-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px}.quick-share-actions{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-top:8px}
    .switch{display:flex;background:var(--bg3);border:1px solid var(--border);border-radius:999px;padding:3px}.switch button{padding:7px 10px;border-radius:999px;background:transparent}.switch button.active{background:var(--gold);color:#160d00}
    .tabbar{position:fixed;left:50%;bottom:calc(12px + env(safe-area-inset-bottom));transform:translateX(-50%);width:min(402px,calc(100% - 22px));height:68px;border:1px solid rgba(255,255,255,.13);background:rgba(12,12,12,.78);backdrop-filter:blur(22px);border-radius:999px;display:grid;grid-template-columns:1fr 1fr 1.12fr 1fr 1fr;gap:4px;padding:7px;z-index:20;box-shadow:0 18px 55px rgba(0,0,0,.42)}
    [data-theme="light"] .tabbar{background:rgba(255,255,255,.76);border-color:rgba(80,58,10,.18)}
    .tabbar button{position:relative;background:transparent;border-radius:999px;color:var(--muted);font-size:10px;font-weight:800;display:grid;place-items:center;gap:2px}.tabbar svg{width:19px;height:19px}.tabbar button.active{color:var(--gold3)}
    .tabbar .shift{background:linear-gradient(135deg,var(--gold3),var(--gold2));color:#160d00;border-radius:22px}.tabbar .shift.active{color:#160d00}
    .view-btn{height:34px;border-radius:8px;background:rgba(212,160,23,.16);border:1px solid rgba(212,160,23,.35);color:var(--gold3);font-size:12px;font-weight:900}
    .toast{position:fixed;left:50%;bottom:96px;transform:translateX(-50%) translateY(20px);background:#151515;color:#fff;border:1px solid #333;border-radius:999px;padding:10px 14px;opacity:0;pointer-events:none;transition:.2s;z-index:50}.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
    .modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:60;place-items:center;padding:20px}.modal.show{display:grid}.modal-card{width:min(100%,390px);background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:16px;box-shadow:var(--shadow)}
    /* ── Dual-action share sheet ── */
    .sheet-overlay{position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:70;opacity:0;pointer-events:none;transition:opacity .25s}
    .sheet-overlay.show{opacity:1;pointer-events:auto}
    .sheet-card{position:absolute;left:50%;bottom:0;transform:translate(-50%,100%);width:min(100%,430px);background:var(--bg2);border:1px solid var(--border);border-bottom:0;border-radius:22px 22px 0 0;padding:8px 16px calc(18px + env(safe-area-inset-bottom));box-shadow:0 -18px 55px rgba(0,0,0,.45);transition:transform .32s cubic-bezier(.32,.72,0,1);touch-action:none;will-change:transform}
    .sheet-overlay.show .sheet-card{transform:translate(-50%,0)}
    .sheet-grip{width:42px;height:5px;border-radius:999px;background:var(--border);margin:6px auto 12px}
    .sheet-title{font-family:"Bricolage Grotesque",sans-serif;font-size:19px;font-weight:800;text-align:center}
    .sheet-sub{color:var(--muted);font-size:12.5px;text-align:center;margin:4px 12px 16px;line-height:1.45}
    .sheet-btn{width:100%;border-radius:14px;padding:15px;font-weight:800;font-size:15px;margin-bottom:9px;transition:transform .1s}
    .sheet-btn:active{transform:scale(.98)}
    .sheet-btn.primary{background:linear-gradient(135deg,var(--gold3),var(--gold2));color:#150d00;border:0}
    .sheet-btn.secondary{background:var(--bg3);border:1px solid var(--border);color:var(--text)}
    .modal-card .preview-message{white-space:pre-wrap;font-family:"Geist Mono",monospace;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:12px;color:var(--text);line-height:1.55}
    .receipt-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}.receipt{aspect-ratio:1;background:var(--bg3);border:1px solid var(--border);border-radius:8px;display:grid;place-items:center;text-align:center;padding:8px;font-size:12px;overflow:hidden}.receipt img{width:100%;height:100%;object-fit:cover;border-radius:6px}
    @media (max-height:500px){.tabbar{height:56px}.tabbar button{font-size:9px}.total{font-size:44px}body{padding-bottom:74px}}
    .qf{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px}
    /* ── BAS Quarter Quick Pull ── */
    .bas-pull{padding:12px 13px;margin-bottom:9px;border-top:3px solid var(--gold)}
    .bas-pull-head{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:10px}
    .bas-fy{font-size:11px;font-weight:700;color:var(--muted)}
    .bas-pull-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:7px}
    .bas-chip{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;padding:8px 3px;min-height:48px;border-radius:12px;border:1px solid var(--border);background:var(--bg2);color:var(--text);transition:transform .1s,background .15s,border-color .15s}
    .bas-chip:active{transform:scale(.95)}
    .bas-chip b{font-family:"Bricolage Grotesque",sans-serif;font-size:15px;line-height:1.05}
    .bas-chip small{font-size:9.5px;color:var(--muted);line-height:1;white-space:nowrap}
    .bas-chip.active{background:linear-gradient(135deg,var(--gold3),var(--gold2));color:#150d00;border-color:transparent}
    .bas-chip.active small{color:#3a2a00}
    @media (max-width:340px){.bas-chip small{font-size:9px}.bas-chip b{font-size:14px}}
    /* ── Reports redesign: Net hero, metric grid, audit, export ── */
    .rep-net{padding:15px 16px;margin-bottom:9px;border-top:3px solid var(--gold);background:linear-gradient(135deg,rgba(212,160,23,.10),rgba(17,17,17,.92))}
    [data-theme="light"] .rep-net{background:linear-gradient(135deg,rgba(212,160,23,.13),rgba(255,255,255,.93))}
    .rep-net .rn-label{font-size:11px;text-transform:uppercase;letter-spacing:.85px;color:var(--muted);font-weight:800}
    .rep-net .rn-val{font-family:"Bricolage Grotesque",sans-serif;font-size:42px;line-height:1;margin:5px 0 3px;font-variant-numeric:tabular-nums;color:var(--green)}
    .rep-net .rn-val.neg{color:var(--red)}
    .rep-net .rn-sub{font-size:11px;color:var(--muted)}
