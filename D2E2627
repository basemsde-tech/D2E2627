/* Recurring-aware expansion: returns the expense INSTANCES that fall inside the active
   report period. Recurring templates are expanded into virtual occurrences (stepping
   weekly/monthly from their anchor date) WITHOUT ever duplicating rows in state.expenses —
   so the underlying data stays a single source of truth and cannot be corrupted. */
function expandExpenses(){
  try{
    const allTime=!!state.repAllTime, lo=state.repStart, hi=state.repEnd, today=localDateStr(new Date());
    const out=[];
    for(const e of (state.expenses||[])){
      if(!e||!e.date)continue;
      if(!e.recurring){
        if(allTime || (lo&&hi&&e.date>=lo&&e.date<=hi)) out.push(Object.assign({},e,{_baseId:e.id}));
        continue;
      }
      const upper=allTime?today:(hi||today);
      let d=parseLocal(e.date), guard=0;
      while(guard++<600){
        const ds=localDateStr(d);
        if(ds>upper)break;
        if(allTime || (lo&&hi&&ds>=lo&&ds<=hi)) out.push(Object.assign({},e,{date:ds,_recurring:true,_baseId:e.id,id:e.id+'@'+ds}));
        if(e.frequency==='weekly')d.setDate(d.getDate()+7); else d.setMonth(d.getMonth()+1);
      }
    }
    return out;
  }catch(err){ return (state.expenses||[]).filter(e=>e&&e.date&&repMatch(e.date)); }
}
